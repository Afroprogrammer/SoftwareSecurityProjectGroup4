# --------------------------------------------------------------------------
# DO NOT ADD REAL SECRET KEYS HERE! 
# Copy this file to `.env` and fill out your local parameters.
# --------------------------------------------------------------------------

# Database Connection (Default is async SQLite for local dev)
DATABASE_URL=sqlite+aiosqlite:///./secure_app.db

# JWT Cryptographic Signing Salt
SECRET_KEY=change_this_to_a_random_secure_string_in_production

# Auto-Seeding Administrator Configuration
DEFAULT_ADMIN_EMAIL=admin@example.local
DEFAULT_ADMIN_PASSWORD=StrongPassword123!

# Fernet symmetric encryption key for sensitive database fields
# Generate with: python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=your_generated_fernet_key_here
