POSTGRES_USER=admin
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB=secure_app

DATABASE_URL=postgresql+asyncpg://app_user:CHANGE_ME@db:5432/secure_app
READONLY_DATABASE_URL=postgresql+asyncpg://read_only_user:CHANGE_ME@db:5432/secure_app

SECRET_KEY=CHANGE_ME_64_CHAR_HEX_STRING
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

FRONTEND_URL=http://localhost:5173
DEFAULT_ADMIN_EMAIL=admin@yourdomain.local
DEFAULT_ADMIN_PASSWORD=CHANGE_ME_STRONG_PASSWORD
